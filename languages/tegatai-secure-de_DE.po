msgid "Auto backup"
msgstr "Auto Backup"

msgid "Enable WAF"
msgstr "WAF aktivieren"

msgid "Login limit"
msgstr "Login Limit"

msgid "Panic button (lockdown)"
msgstr "PANIC BUTTON (Lockdown)"

msgid "Quick access"
msgstr "Schnellzugriff"
msgid "Instantly blocks all external access and secures the perimeter."
msgstr "Blockiert sofort jeden externen Zugriff und riegelt die Website ab."

msgid "Activates the Web Application Firewall to block malicious requests."
msgstr "Aktiviert die Web Application Firewall, um bösartige Anfragen zu blockieren."

msgid "Block Bad Bots"
msgstr "Bad Bots blockieren"

msgid "Blocks known malicious bots, scrapers, and automated attack tools."
msgstr "Blockiert bekannte bösartige Bots, Scraper und automatisierte Angriffstools."

msgid "Rate Limit"
msgstr "Rate Limit"

msgid "Prevents brute-force attacks by limiting requests per minute."
msgstr "Verhindert Brute-Force-Angriffe durch Begrenzung der Anfragen pro Minute."

msgid "404 Trap"
msgstr "404 Falle"

msgid "Bans IPs that generate too many 404 Not Found errors."
msgstr "Sperrt IPs, die zu viele 404-Fehler verursachen."

msgid "Block AI Bots"
msgstr "KI-Bots blockieren"

msgid "Stops OpenAI, ChatGPT, and other AI scrapers from crawling your content."
msgstr "Hindert OpenAI, ChatGPT und andere KI-Scraper daran, deine Inhalte zu crawlen."

msgid "Block SEO Bots"
msgstr "SEO-Bots blockieren"

msgid "Blocks aggressive SEO crawlers like Ahrefs or Semrush."
msgstr "Blockiert aggressive SEO-Crawler wie Ahrefs oder Semrush."

msgid "Disable Directory Browsing"
msgstr "Directory Browsing deaktivieren"

msgid "Prevents attackers from seeing lists of your files."
msgstr "Verhindert, dass Angreifer Dateilisten deines Servers sehen können."

msgid "Protect Sensitive Files"
msgstr "Sensible Dateien schützen"

msgid "Blocks access to .env, .sql, .bak, .log, and .git files."
msgstr "Blockiert den Zugriff auf .env, .sql, .bak, .log und .git Dateien."

msgid "Block System Files"
msgstr "Systemdateien blockieren"

msgid "Hides readme.html, license.txt, and wp-config.php from the web."
msgstr "Versteckt readme.html, license.txt und wp-config.php vor dem Web."

msgid "Block Dotfiles"
msgstr "Dotfiles blockieren"

msgid "Denies access to hidden files (e.g., .htaccess)."
msgstr "Verweigert den Zugriff auf versteckte Dateien (z.B. .htaccess)."

msgid "Block XML-RPC"
msgstr "XML-RPC blockieren"

msgid "Disables xmlrpc.php to prevent DDoS and brute-force attacks."
msgstr "Deaktiviert die xmlrpc.php, um DDoS- und Brute-Force-Angriffe zu verhindern."

msgid "Disable PHP in Uploads"
msgstr "PHP in Uploads deaktivieren"

msgid "Prevents execution of malicious backdoors in your media folder."
msgstr "Verhindert die Ausführung von Malware und Backdoors in deinem Upload-Ordner."

msgid "Ultimate Bad Bot Filter"
msgstr "Ultimate Bad Bot Filter"

msgid "Strict Nginx-level blocking for hacking tools."
msgstr "Strenge Blockierung von Hacking-Tools direkt auf Nginx-Ebene."

msgid "Hotlink Protection"
msgstr "Hotlink Schutz"

msgid "Prevents other sites from embedding your images and stealing bandwidth."
msgstr "Verhindert, dass andere Seiten deine Bilder einbetten und Bandbreite stehlen."

msgid "Login Protection"
msgstr "Login Schutz"

msgid "Disable App Passwords"
msgstr "App-Passwörter deaktivieren"

msgid "Turns off the WordPress application passwords feature."
msgstr "Schaltet die WordPress-Funktion für App-Passwörter ab."

msgid "Trusted Devices"
msgstr "Vertrauenswürdige Geräte"

msgid "Warns via email upon logins from unknown devices."
msgstr "Warnt per E-Mail bei Logins von unbekannten Geräten."

msgid "Block wp-login.php"
msgstr "wp-login.php blockieren"

msgid "Disables the default login route (requires Custom Slug)."
msgstr "Deaktiviert die Standard-Login-Route (erfordert einen Custom Slug!)."

msgid "Hide /wp-admin/"
msgstr "/wp-admin/ verstecken"

msgid "Redirects unauthenticated users away from the admin area."
msgstr "Leitet nicht authentifizierte Benutzer vom Admin-Bereich weg."

msgid "Idle Logout (60m)"
msgstr "Automatischer Logout (60 Min)"

msgid "Automatically logs out inactive administrators after 60 minutes."
msgstr "Meldet inaktive Administratoren nach 60 Minuten automatisch ab."

msgid "Enable Magic Links"
msgstr "Magic Links aktivieren"

msgid "Allows passwordless login via a secure email link."
msgstr "Erlaubt passwortlose Logins über einen sicheren E-Mail-Link."

msgid "Enable Honeypot"
msgstr "Honeypot aktivieren"

msgid "Adds an invisible field to catch automated spam bots."
msgstr "Fügt ein unsichtbares Feld hinzu, um automatisierte Spam-Bots abzufangen."

msgid "Minimum Fill Time"
msgstr "Minimale Ausfüllzeit"

msgid "Blocks forms submitted too quickly (typical bot behavior)."
msgstr "Blockiert Formulare, die zu schnell abgeschickt wurden (typisches Bot-Verhalten)."

msgid "Referrer Check"
msgstr "Referrer-Prüfung"

msgid "Ensures form submissions come from your own site."
msgstr "Stellt sicher, dass Formulareingaben von deiner eigenen Seite stammen."

msgid "Block Trash Mails"
msgstr "Trash-Mails blockieren"

msgid "Rejects disposable email addresses during registration."
msgstr "Lehnt Wegwerf-E-Mail-Adressen bei der Registrierung ab."

msgid "Enable Turnstile CAPTCHA"
msgstr "Turnstile CAPTCHA aktivieren"

msgid "Privacy-friendly Cloudflare CAPTCHA for login and comments."
msgstr "Datenschutzfreundliches Cloudflare CAPTCHA für Logins und Kommentare."

msgid "Hide WP Version"
msgstr "WP Version verstecken"

msgid "Removes the WordPress version number from your source code."
msgstr "Entfernt die WordPress-Versionsnummer aus dem Quellcode."

msgid "Disable XML-RPC (WP Core)"
msgstr "XML-RPC deaktivieren (WP Core)"

msgid "Turns off the XML-RPC API internally."
msgstr "Schaltet die XML-RPC API intern ab."

msgid "Disable File Editor"
msgstr "Datei-Editor deaktivieren"

msgid "Prevents editing plugins and themes via the WP dashboard."
msgstr "Verhindert das Bearbeiten von Plugins und Themes über das WP-Dashboard."

msgid "Block User Enumeration"
msgstr "Benutzer-Ausspähung blockieren"

msgid "Stops attackers from discovering your usernames."
msgstr "Hindert Angreifer daran, deine Benutzernamen herauszufinden."

msgid "Admin Honeypot"
msgstr "Admin Honeypot"

msgid "Permanently bans anyone trying to log in as admin."
msgstr "Sperrt jeden dauerhaft, der versucht, sich als "admin" einzuloggen."

msgid "Privilege Escalation Guard"
msgstr "Rechteausweitungs-Schutz"

msgid "Prevents unauthorized users from upgrading to Administrator."
msgstr "Verhindert, dass unbefugte Benutzer sich Administrator-Rechte geben."

msgid "Enable Email Alerts"
msgstr "E-Mail-Warnungen aktivieren"

msgid "Receive notifications for critical security events."
msgstr "Erhalte Benachrichtigungen bei kritischen Sicherheitsereignissen."

msgid "Enable 2FA"
msgstr "2FA aktivieren"

msgid "Enforces Two-Factor Authentication for administrators."
msgstr "Erzwingt die Zwei-Faktor-Authentifizierung für Administratoren."

msgid "X-Frame-Options"
msgstr "X-Frame-Options"

msgid "Prevents your site from being framed (Clickjacking protection)."
msgstr "Verhindert, dass deine Seite in Iframes geladen wird (Clickjacking-Schutz)."

msgid "X-Content-Type-Options"
msgstr "X-Content-Type-Options"

msgid "Stops browsers from MIME-sniffing."
msgstr "Verhindert, dass Browser den MIME-Typ erraten (Sniffing)."

msgid "X-XSS-Protection"
msgstr "X-XSS-Protection"

msgid "Enables legacy browser XSS filtering."
msgstr "Aktiviert den XSS-Filter älterer Browser."

msgid "HSTS (SSL)"
msgstr "HSTS (SSL)"

msgid "Enforces strict HTTPS connections."
msgstr "Erzwingt strikte HTTPS-Verbindungen."

msgid "Referrer Policy"
msgstr "Referrer Policy"

msgid "Controls how much referrer information is passed to external sites."
msgstr "Kontrolliert, wie viele Referrer-Informationen an externe Seiten weitergegeben werden."

msgid "Permissions-Policy"
msgstr "Permissions-Policy"

msgid "Restricts access to browser features (camera, microphone)."
msgstr "Beschränkt den Zugriff auf Browser-Funktionen (Kamera, Mikrofon)."

msgid "Content Security Policy"
msgstr "Content Security Policy"

msgid "Mitigates XSS by controlling resource loading sources."
msgstr "Mildert XSS-Angriffe durch Kontrolle der Ladequellen für Ressourcen."

msgid "Auto-Quarantine (IPS)"
msgstr "Auto-Quarantäne (IPS)"

msgid "Automatically moves detected malware to a safe location."
msgstr "Verschiebt erkannte Malware automatisch in einen sicheren Ordner."

msgid "IP Guard"
msgstr "IP Guard"

msgid "Invalidates the session if the users IP address changes."
msgstr "Macht die Sitzung ungültig, falls sich die IP-Adresse des Benutzers ändert."

msgid "Browser Guard"
msgstr "Browser Guard"

msgid "Invalidates the session if the users browser changes."
msgstr "Macht die Sitzung ungültig, falls sich der Browser (User-Agent) des Benutzers ändert."

msgid "Restrict REST API"
msgstr "REST API einschränken"

msgid "Requires authentication for most REST API endpoints."
msgstr "Erfordert eine Authentifizierung für die meisten REST-API-Endpunkte."

msgid "Disable Right-Click"
msgstr "Rechtsklick deaktivieren"

msgid "Prevents basic right-clicking on your website content."
msgstr "Verhindert den normalen Rechtsklick auf deine Website-Inhalte."

msgid "Enable Copy Protection"
msgstr "Kopierschutz aktivieren"

msgid "Stops users from highlighting and copying text."
msgstr "Hindert Benutzer daran, Text zu markieren und zu kopieren."

msgid "Upload guard"
msgstr "Upload Guard"

msgid "Scans files during upload for malicious payloads."
msgstr "Überprüft Dateien während des Uploads auf bösartige Inhalte."

